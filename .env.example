# Vendor Risk Assessor Configuration

# ── LLM Model Configuration ─────────────────────────────────────────
# Supported formats:
#   Gemini:  gemini-2.0-flash-lite, gemini-2.0-flash, gemini-1.5-pro
#   Ollama:  ollama_chat/llama3.1, ollama_chat/qwen2.5, ollama_chat/mistral
#            (use the ollama_chat/ prefix — better tool-calling & JSON output)
#   OpenAI:  openai/gpt-4o, openai/gpt-4o-mini  (requires OPENAI_API_KEY)
#
# AGENT_MODEL     → used by the CLI (primary local handler = Ollama).
# WEB_AGENT_MODEL → used by the web interface. Options:
#   * Gemini      — WEB_AGENT_MODEL=gemini-2.0-flash-lite  (needs GOOGLE_API_KEY
#                   + free-tier/paid quota).
#   * Hugging Face — WEB_AGENT_MODEL=huggingface/Qwen/Qwen2.5-7B-Instruct
#                   (serverless, good for a deployed host; needs
#                   HUGGINGFACE_API_KEY). Recommended fallback when Gemini quota
#                   is exhausted. Use an -Instruct/chat model (tool calling).
#   * Ollama      — WEB_AGENT_MODEL=ollama_chat/llama3.1  (fully local, no key;
#                   needs 'ollama serve' running and the model pulled).
# Reports are scored deterministically regardless, so a weak model still yields
# a complete report (narrative falls back to a template).
AGENT_MODEL=ollama_chat/llama3.1
WEB_AGENT_MODEL=huggingface/Qwen/Qwen2.5-7B-Instruct

# Ollama server URL (only needed when using ollama*/* models)
OLLAMA_BASE_URL=http://localhost:11434

# NVD API Key (free, get from https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=your_nvd_api_key_here

# Google Gemini API Key — needed only if WEB_AGENT_MODEL is a gemini-* model
GOOGLE_API_KEY=your_google_api_key_here

# Hugging Face token — needed if WEB_AGENT_MODEL is a huggingface/* model
# (get one at https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your_hf_token_here

# Search Provider: tavily, serpapi, or duckduckgo
SEARCH_PROVIDER=duckduckgo

# Search API Key (required for tavily or serpapi, not needed for duckduckgo)
SEARCH_API_KEY=your_search_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# MCP Server Transport: stdio or sse
MCP_TRANSPORT=stdio
MCP_SERVER_PORT=8081
