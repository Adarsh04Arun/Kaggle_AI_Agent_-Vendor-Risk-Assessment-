# Vendor Risk Assessor Configuration

# ── LLM Model Configuration ─────────────────────────────────────────
# Supported formats:
#   Gemini:  gemini-2.0-flash-lite, gemini-2.0-flash, gemini-1.5-pro
#   Ollama:  ollama_chat/llama3.1, ollama_chat/qwen2.5, ollama_chat/mistral
#            (use the ollama_chat/ prefix — better tool-calling & JSON output)
#   OpenAI:  openai/gpt-4o, openai/gpt-4o-mini  (requires OPENAI_API_KEY)
#
# AGENT_MODEL     → used by the CLI (primary local handler = Ollama).
# WEB_AGENT_MODEL → used by the web interface.
#   * Default is Gemini (needs GOOGLE_API_KEY + free-tier/paid quota).
#   * To run the WEB UI fully local with no API key / no quota limits, point
#     it at Ollama instead — e.g. set:
#         WEB_AGENT_MODEL=ollama_chat/llama3.1
#     (requires 'ollama serve' running and the model pulled). Reports are then
#     scored deterministically if the local model can't emit clean JSON.
AGENT_MODEL=ollama_chat/llama3.1
WEB_AGENT_MODEL=gemini-2.0-flash-lite

# Ollama server URL (only needed when using ollama*/* models)
OLLAMA_BASE_URL=http://localhost:11434

# NVD API Key (free, get from https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=your_nvd_api_key_here

# Google Gemini API Key — REQUIRED for the web interface (uses Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Search Provider: tavily, serpapi, or duckduckgo
SEARCH_PROVIDER=duckduckgo

# Search API Key (required for tavily or serpapi, not needed for duckduckgo)
SEARCH_API_KEY=your_search_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# MCP Server Transport: stdio or sse
MCP_TRANSPORT=stdio
MCP_SERVER_PORT=8081
